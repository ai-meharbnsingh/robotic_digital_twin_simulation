# ============================================================
# Robotic Digital Twin — Environment Variables
# ============================================================
# Copy this file to .env and adjust values for your environment.
# docker-compose.yml reads these; they override the defaults there.

# ── MongoDB ──
# Connection URL for state IPC between C++ FMS and Python API
MONGODB_URL=mongodb://mongodb:27017

# ── Redis ──
# Real-time cache for robot positions and telemetry
REDIS_URL=redis://redis:6379

# ── InfluxDB ──
# Time-series database for fleet telemetry
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=rdt-influx-token
INFLUXDB_ORG=rdt
INFLUXDB_BUCKET=fleet_telemetry

# ── RabbitMQ ──
# Message broker for task queue and event bus
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=fms
RABBITMQ_PASS=fms_pass

# ── Warehouse Configuration ──
# Which warehouse map to load (filename without extension from configs/warehouses/)
WAREHOUSE_CONFIG=simple_grid

# ── Robot Configuration ──
# Which robot preset to load (filename without extension from configs/robots/)
ROBOT_CONFIG=differential_drive

# ── C++ FMS Server ──
# TCP port for robot protocol V1 communication
FMS_TCP_PORT=65123
# REST port for fleet management API
FMS_REST_PORT=7012

# ── Python FastAPI ──
# REST API port for intelligence + dashboard backend
API_PORT=8029

# ── Logging ──
# Log level: debug, info, warning, error, critical
LOG_LEVEL=info

# ── Grafana ──
# Admin password for Grafana dashboard
GF_SECURITY_ADMIN_PASSWORD=admin
