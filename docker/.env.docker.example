# Docker Compose secrets — copy to docker/.env before running
# Usage: cp docker/.env.docker.example docker/.env

# MongoDB
MONGO_USER=rdt
MONGO_PASSWORD=CHANGE_ME_mongo_secret

# Redis
REDIS_PASSWORD=CHANGE_ME_redis_secret

# RabbitMQ
RABBITMQ_USER=fms
RABBITMQ_PASSWORD=CHANGE_ME_rabbitmq_secret

# InfluxDB
INFLUXDB_USER=admin
INFLUXDB_PASSWORD=CHANGE_ME_influx_secret
INFLUXDB_TOKEN=CHANGE_ME_influx_token

# Grafana
GRAFANA_PASSWORD=CHANGE_ME_grafana_secret

# API authentication (empty = disabled for local dev)
API_KEY=
