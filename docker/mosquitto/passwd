# Mosquitto password file
# ─────────────────────────────────────────────────────
# This file is NOT active by default (allow_anonymous = true in dev).
#
# To activate password authentication:
#   1. Uncomment password_file in mosquitto.conf
#   2. Set allow_anonymous false
#   3. Generate hashed passwords:
#      docker exec mosquitto mosquitto_passwd -b /mosquitto/config/passwd mqtt_user your_secure_password
#
# Default dev credential (plaintext — hash before production use):
# mqtt_user:changeme_in_production
#
# To hash this file:
#   mosquitto_passwd -U /mosquitto/config/passwd
