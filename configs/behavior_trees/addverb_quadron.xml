<?xml version="1.0" encoding="UTF-8"?>
<!--
  Addverb Quadron Pallet Shuttle Behavior Tree — BTCPP v4 format
  Robot type: unidirectional (Rail-guided pallet shuttle)
  Lifecycle: idle -> accept_task -> enter_lane -> move_to_pallet -> load_pallet -> exit_lane -> move_to_drop -> unload_pallet -> check_battery -> charge -> repeat

  Key features:
  - Rail-guided: linear motion only, zero angular velocity
  - Enter/exit lane actions: shuttle enters deep-lane storage rails
  - Encoder-based positioning: 2mm precision
  - Lifter for pallet grab/release
  - 4 m/s top speed on rails
  - 50kg payload (light pallet shuttle)
  - No LiDAR — uses encoder + limit switches for safety
-->
<root BTCPP_format="4" main_tree_to_execute="Quadron_Main">

  <!-- ============================================================ -->
  <!-- MAIN TREE: Rail shuttle loop                                 -->
  <!-- ============================================================ -->
  <BehaviorTree ID="Quadron_Main">
    <ReactiveSequence>
      <!-- Rail limit switch safety — HasErrors covers rail limit triggers -->
      <Fallback>
        <Inverter>
          <Condition ID="HasErrors"/>
        </Inverter>
        <Action ID="EmergencyStop"/>
      </Fallback>

      <!-- Error monitor -->
      <Fallback>
        <Inverter>
          <Condition ID="HasErrors"/>
        </Inverter>
        <SubTree ID="ErrorRecovery"/>
      </Fallback>

      <!-- Main shuttle loop -->
      <Sequence>
        <RepeatNode num_cycles="-1">
          <Sequence>
            <SubTree ID="WaitForTask"/>
            <SubTree ID="ShuttleLaneOperation"/>
            <SubTree ID="BatteryManagement"/>
          </Sequence>
        </RepeatNode>
      </Sequence>
    </ReactiveSequence>
  </BehaviorTree>

  <!-- ============================================================ -->
  <!-- SUBTREE: WaitForTask                                         -->
  <!-- ============================================================ -->
  <BehaviorTree ID="WaitForTask">
    <RetryNode num_attempts="-1">
      <Sequence>
        <Condition ID="TaskAvailable"/>
        <Action ID="AcceptTask" task_id="{task_id}" pickup_node="{pickup_node}" drop_node="{drop_node}"/>
      </Sequence>
    </RetryNode>
  </BehaviorTree>

  <!-- ============================================================ -->
  <!-- SUBTREE: ShuttleLaneOperation — deep-lane storage cycle      -->
  <!-- Enter lane -> travel to pallet position -> load -> reverse   -->
  <!-- exit lane -> travel to drop -> unload                        -->
  <!-- ============================================================ -->
  <BehaviorTree ID="ShuttleLaneOperation">
    <Sequence>
      <!-- Phase 1: Enter storage lane — navigate to lane entry node -->
      <Action ID="NavigateToNode"
              target_node="{pickup_lane}"
              action_code="10"
              velocity_profile="rail_fast"
              allow_rotation="false"
              description="enter_storage_lane"/>

      <!-- Phase 2: Travel along rail to pallet position (encoder-guided) -->
      <Action ID="NavigateToNode"
              target_node="{pickup_node}"
              action_code="0"
              velocity_profile="rail_fast"
              allow_rotation="false"/>

      <!-- Phase 3: Lower lifter, grab pallet (5 seconds) -->
      <Action ID="ExecuteAttachment"
              action_code="14"
              timeout_s="8.0"
              description="start_loading"/>

      <!-- Confirm pallet secured -->
      <Condition ID="CargoSecured"/>

      <!-- Phase 4: Exit lane with pallet — navigate to lane exit node -->
      <Action ID="NavigateToNode"
              target_node="{pickup_lane}"
              action_code="11"
              velocity_profile="rail_loaded"
              allow_rotation="false"
              description="exit_storage_lane"/>

      <!-- Phase 5: Travel to drop station -->
      <Action ID="NavigateToNode"
              target_node="{drop_node}"
              action_code="0"
              velocity_profile="rail_loaded"
              allow_rotation="false"/>

      <!-- Phase 6: Unload pallet (5 seconds) -->
      <Action ID="ExecuteAttachment"
              action_code="15"
              timeout_s="8.0"
              description="start_unloading"/>

      <!-- Report task complete -->
      <Action ID="ReportTaskComplete" task_id="{task_id}"/>
    </Sequence>
  </BehaviorTree>

  <!-- ============================================================ -->
  <!-- SUBTREE: BatteryManagement — charge if below 10% critical    -->
  <!-- Quadron has 0.8 kWh battery, 30 min charge time              -->
  <!-- ============================================================ -->
  <BehaviorTree ID="BatteryManagement">
    <Fallback>
      <Condition ID="BatteryAboveThreshold" threshold_pct="10"/>

      <Sequence>
        <!-- Navigate to nearest charge dock on rail network -->
        <Action ID="NavigateToNode"
                target_node="{nearest_dock}"
                action_code="0"
                velocity_profile="rail_fast"
                allow_rotation="false"/>

        <Action ID="DockAtCharger"
                action_code="2"
                timeout_s="20.0"/>

        <Action ID="StartCharging"
                action_code="3"/>

        <Action ID="WaitUntilCharged"
                target_pct="95"/>

        <Action ID="UndockFromCharger"
                action_code="4"
                timeout_s="10.0"/>
      </Sequence>
    </Fallback>
  </BehaviorTree>

  <!-- ============================================================ -->
  <!-- SUBTREE: ErrorRecovery                                       -->
  <!-- ============================================================ -->
  <BehaviorTree ID="ErrorRecovery">
    <Sequence>
      <Fallback>
        <Action ID="SendActionCode"
                action_code="31"
                description="reset_errors"
                timeout_s="5.0"/>

        <Action ID="SendActionCode"
                action_code="51"
                description="hard_reset"
                timeout_s="15.0"/>
      </Fallback>

      <Action ID="WaitSeconds" seconds="2.0"/>
      <Condition ID="NoErrors"/>
    </Sequence>
  </BehaviorTree>

</root>
